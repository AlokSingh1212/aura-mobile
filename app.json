{
  "expo": {
    "name": "AURAGRAM",
    "slug": "auragram-mobile",
    "jsEngine": "hermes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "auragrammobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.aisastra.auragram"
    },
    "android": {
      "package": "com.aisastra.auragram",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 180
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-video",
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "AURA needs access to your photos to update your profile picture and publish stories."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "AURA needs your camera to record Reels and capture product moments.",
          "microphonePermission": "AURA needs your microphone to record audio with your Reels.",
          "recordAudioAndroid": true
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c00feb62-3dda-43cd-9976-97af9dcf2600"
      }
    },
    "owner": "aloksingh2121"
  }
}
