# Copy to .env for local overrides (Expo loads EXPO_PUBLIC_* automatically)

# Production API (required for release builds)
EXPO_PUBLIC_API_HOST=https://ai-marketplace-delta-five.vercel.app

# Google OAuth (EAS secrets — optional for social login)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Agora (optional — live uses server-minted tokens when configured)
EXPO_PUBLIC_AGORA_APP_ID=

# Sentry / analytics (optional)
EXPO_PUBLIC_SENTRY_DSN=
